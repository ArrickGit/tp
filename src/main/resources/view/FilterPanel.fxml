<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:id="filterPanel">

    <padding>
        <Insets top="15" right="10" bottom="10" left="10" />
    </padding>

    <Label text="Filters" styleClass="panel-title" />

    <VBox spacing="8">
        <Label text="All" styleClass="filterItem" />
        <Label text="Interviewed" styleClass="filterItem" />
        <Label text="Not Interviewed" styleClass="filterItem" />
    </VBox>

</VBox>