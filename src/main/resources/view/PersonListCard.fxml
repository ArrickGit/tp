<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS" styleClass="person-card-grid">
    <columnConstraints>
      <ColumnConstraints hgrow="ALWAYS" minWidth="160" prefWidth="220" />
      <ColumnConstraints hgrow="ALWAYS" minWidth="140" prefWidth="180" />
    </columnConstraints>
    <VBox alignment="TOP_LEFT" spacing="6" minHeight="120" GridPane.columnIndex="0" styleClass="person-card-section">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <HBox spacing="0.5" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <!-- Ensures that the label text is never truncated -->
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
      </HBox>
      <Label text="CONTACT" styleClass="section_kicker" />
      <Label fx:id="email" styleClass="cell_small_label" text="\$email" wrapText="true" />
      <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" wrapText="true" />
      <FlowPane fx:id="tags" />
    </VBox>

    <VBox alignment="TOP_LEFT" spacing="6" minHeight="120" GridPane.columnIndex="1" styleClass="person-card-section">
      <padding>
        <Insets top="5" right="12" bottom="5" left="8" />
      </padding>
      <Label text="STATUS" styleClass="section_kicker" />
      <Label fx:id="interviewed" styleClass="cell_small_label" text="\$interviewed" />
      <Label fx:id="address" styleClass="cell_small_label" text="\$address" wrapText="true" />
      <Label fx:id="remark" styleClass="cell_small_label" text="\$remark " wrapText="true" />
    </VBox>
  </GridPane>
</HBox>
